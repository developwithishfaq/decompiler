# --- Secrets / signing material (NEVER commit) ---
*.keystore
*.jks
apk_tool_gui.config.json

# --- Machine-specific tool paths (resolved per-machine at runtime) ---
apk_tool_gui.tools.json

# --- Build artifacts / test inputs ---
*.apk
*.apk.idsig
*.idsig
*.apk.cache/

# --- Runtime-generated data ---
# Frida scripts are auto-seeded by the app on first run
scripts/
*.log

# --- Python ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# --- OS / editor ---
Thumbs.db
.DS_Store
*.lnk
